# .env.example
#
# Copy this file to .env and fill in the real values.
# NEVER commit .env — it is gitignored.
#
# Two modes:
#
#   VAULT MODE (recommended for staging/production)
#     Set VAULT_ADDR, VAULT_ROLE_ID, VAULT_SECRET_ID.
#     Leave INOVAR_USERNAME and INOVAR_PASSWORD blank or unset —
#     the app will fetch them from Vault at startup.
#
#   ENV-ONLY MODE (local dev without Vault)
#     Leave VAULT_ADDR blank.
#     Set INOVAR_USERNAME, INOVAR_PASSWORD, INOVAR_URL directly.

# ── Vault (AppRole) ──────────────────────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_ROLE_ID=your-role-id-here
VAULT_SECRET_ID=your-secret-id-here

# ── Inovar (env-only fallback / local dev) ───────────────────────────────────
INOVAR_USERNAME=your_inovar_username
INOVAR_PASSWORD=your_inovar_password
INOVAR_URL=https://your-school-portal.example.com/alunos/Inicial.wgx

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prof_db
